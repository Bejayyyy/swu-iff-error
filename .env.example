# Copy to .env and fill with your Firebase project values (Console → Project settings → Your apps).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Temporary Developer self-registration (disable before production)
VITE_ALLOW_DEV_SIGNUP=true

# --- First-time setup ---
# 1. Enable Email/Password in Authentication.
# 2. Set VITE_ALLOW_DEV_SIGNUP=true, restart npm run dev, open /developer-signup
#    OR manually add users/{uid} in Firestore with role "developer"
# 3. Deploy rules: firebase deploy --only firestore:rules
