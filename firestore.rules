rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to safely check if user doc exists
    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Safer version that checks existence first
    function hasRoleSafe(role) {
      return isSignedIn()
        && userDocExists()
        && userDoc().data.role == role
        && userDoc().data.status == 'active';
    }

    function hasRole(role) {
      return hasRoleSafe(role);
    }

    function isDeveloper() {
      return hasRole('developer');
    }

    function isRegistrar() {
      return hasRole('registrar');
    }

    function isStaffRole(role) {
      return role in ['dean', 'organization_head', 'teacher', 'gsd', 'student_life'];
    }

    function roleDefinitionExists(role) {
      return exists(/databases/$(database)/documents/role_definitions/$(role));
    }

    function isStaffRoleOrDefined(role) {
      return isStaffRole(role) || roleDefinitionExists(role);
    }

    function hasPermission(permission) {
      return isSignedIn()
        && userDocExists()
        && userDoc().data.status == 'active'
        && (
          userDoc().data.role == 'registrar'
          || (
            userDoc().data.permissions != null
            && permission in userDoc().data.permissions
          )
        );
    }

    function canManageBuildings() {
      return hasPermission('buildings.manage');
    }

    function isMainRole() {
      return isSignedIn() && userDocExists() && (
        userDoc().data.role == 'registrar'
        || userDoc().data.role == 'dean'
        || userDoc().data.role == 'organization_head'
        || userDoc().data.role == 'teacher'
        || userDoc().data.role == 'gsd'
        || userDoc().data.role == 'student_life'
        || roleDefinitionExists(userDoc().data.role)
      ) && userDoc().data.status == 'active';
    }

    function isPhinmaedEmail() {
      return request.auth.token.email.matches('.*@phinmaed\\.com$');
    }

    function callerIsSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isProvisionalDeveloperSignup(userId) {
      return isSignedIn()
        && isPhinmaedEmail()
        && callerIsSelf(userId)
        && !exists(/databases/$(database)/documents/users/$(userId))
        && request.resource.data.role == 'developer'
        && request.resource.data.provisionalDeveloper == true
        && request.resource.data.status == 'active'
        && request.resource.data.email == request.auth.token.email;
    }

    // Users collection - Most permissive rule first to allow self-read
    match /users/{userId} {
      // Allow users to read their own document without role check (avoids circular dependency)
      allow read: if isSignedIn() && isPhinmaedEmail() && callerIsSelf(userId);
      
      // Allow reading invite documents by email match (for account migration)
      // This allows reading documents like "invite_email@phinmaed.com" when the user's email matches
      allow read: if isSignedIn() && isPhinmaedEmail() && resource.data.email == request.auth.token.email;
      
      // Allow reading if user has proper role
      allow read: if isSignedIn() && isPhinmaedEmail() && userDocExists() && (isDeveloper() || isMainRole());

      // Allow creating own account during migration or provisional developer signup
      allow create: if isSignedIn() && isPhinmaedEmail() && callerIsSelf(userId)
        && request.resource.data.email == request.auth.token.email;

      allow create: if isProvisionalDeveloperSignup(userId)
        || (
          isDeveloper()
          && isPhinmaedEmail()
          && request.resource.data.role == 'registrar'
          && request.resource.data.email.matches('.*@phinmaedcom$')
          && request.resource.data.status in ['active', 'inactive']
        )
        || (
          isRegistrar()
          && isPhinmaedEmail()
          && isStaffRoleOrDefined(request.resource.data.role)
          && request.resource.data.email.matches('.*@phinmaed\\.com$')
          && request.resource.data.status in ['active', 'inactive']
        );

      // Allow updating invite document to mark as migrated
      allow update: if isSignedIn()
        && isPhinmaedEmail()
        && resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasAny(['migratedToUid', 'status']);

      allow update: if isDeveloper()
        && isPhinmaedEmail()
        && resource.data.role == 'registrar'
        && request.resource.data.role == 'registrar'
        && request.resource.data.email.matches('.*@phinmaed\\.com$')
        && request.resource.data.status in ['active', 'inactive'];

      allow update: if isSignedIn()
        && isPhinmaedEmail()
        && isStaffRole(resource.data.role)
        && resource.data.email == request.auth.token.email
        && request.resource.data.email == resource.data.email;

      allow update: if isRegistrar()
        && isPhinmaedEmail()
        && isStaffRoleOrDefined(resource.data.role)
        && isStaffRoleOrDefined(request.resource.data.role)
        && request.resource.data.email == resource.data.email
        && request.resource.data.email.matches('.*@phinmaed\\.com$')
        && request.resource.data.status in ['active', 'inactive'];

      // Allow updating own lastLoginAt without role check
      allow update: if isSignedIn()
        && isPhinmaedEmail()
        && callerIsSelf(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt', 'updatedAt']);

      allow delete: if (isDeveloper() || isRegistrar()) 
        && isPhinmaedEmail() 
        && (resource.data.role == 'registrar' || isStaffRoleOrDefined(resource.data.role));

      // Course schedules subcollection - deans can manage their own, registrars can read all
      match /course_schedules/{section} {
        allow read: if isMainRole() && isPhinmaedEmail();
        allow create, update, delete: if isPhinmaedEmail() && (
          isRegistrar() || (hasRole('dean') && callerIsSelf(userId))
        );

        match /entries/{entryId} {
          // Allow teachers to read entries where they are the instructor
          allow read: if isMainRole() && isPhinmaedEmail() && (
            isRegistrar() 
            || (hasRole('dean') && callerIsSelf(userId))
            || (hasRole('teacher') && userDocExists() && resource.data.instructor == userDoc().data.displayName)
          );
          allow create, update, delete: if isPhinmaedEmail() && (
            isRegistrar() || (hasRole('dean') && callerIsSelf(userId))
          );
        }
      }
    }

    match /registrar_management/{registrarId} {
      allow read: if isDeveloper() && isPhinmaedEmail();
      allow create, update, delete: if isDeveloper() && isPhinmaedEmail();
    }

    match /permissions/{permissionId} {
      allow read: if isSignedIn() && isPhinmaedEmail() && (isDeveloper() || isRegistrar());
      allow write: if isDeveloper() && isPhinmaedEmail();
    }

    match /role_definitions/{roleId} {
      allow read: if isSignedIn() && isPhinmaedEmail() && (isDeveloper() || isMainRole());
      allow create, update, delete: if isRegistrar() && isPhinmaedEmail();
    }

    function isDean() {
      return hasRole('dean');
    }

    function isPlotRecipientData(plotData) {
      return isSignedIn()
        && (
          (plotData.recipientUids != null && request.auth.uid in plotData.recipientUids)
          || (plotData.recipientEmails != null && plotData.recipientEmails.hasAny([request.auth.token.email]))
        );
    }

    function isActivePlotRecipient(plotData) {
      return isSignedIn()
        && isPlotRecipientData(plotData)
        && (
          plotData.activeRecipientUid == request.auth.uid
          || (
            isDean()
            && plotData.activeRecipientUid == null
            && plotData.recipientEmails != null
            && plotData.recipientEmails.hasAny([request.auth.token.email])
          )
        );
    }

    match /schedule_plot_requests/{plotId} {
      allow read: if isMainRole() && isPhinmaedEmail() && (
        isRegistrar()
        || isPlotRecipientData(resource.data)
      );
      allow create, delete: if isRegistrar() && isPhinmaedEmail();
      allow update: if isRegistrar() && isPhinmaedEmail();

      match /schedule_entries/{entryId} {
        allow read: if isMainRole() && isPhinmaedEmail() && (
          isRegistrar()
          || isPlotRecipientData(get(/databases/$(database)/documents/schedule_plot_requests/$(plotId)).data)
        );
        allow create, update, delete: if isPhinmaedEmail() && (
          isRegistrar()
          || isActivePlotRecipient(get(/databases/$(database)/documents/schedule_plot_requests/$(plotId)).data)
          || (
            hasRole('dean')
            && isPlotRecipientData(get(/databases/$(database)/documents/schedule_plot_requests/$(plotId)).data)
            && get(/databases/$(database)/documents/schedule_plot_requests/$(plotId)).data.activeRecipientUid == null
          )
        );
      }
    }

    match /academic_calendars/{schoolYearId} {
      allow read: if isMainRole() && isPhinmaedEmail();
      allow write: if isRegistrar() && isPhinmaedEmail();

      match /holidays/{holidayId} {
        allow read: if isMainRole() && isPhinmaedEmail();
        allow write: if isRegistrar() && isPhinmaedEmail();
      }

      match /no_class_periods/{periodId} {
        allow read: if isMainRole() && isPhinmaedEmail();
        allow write: if isRegistrar() && isPhinmaedEmail();
      }
    }

    match /buildings/{buildingId} {
      allow read: if isMainRole() && isPhinmaedEmail();
      allow write: if (isRegistrar() || canManageBuildings()) && isPhinmaedEmail();

      match /floors/{floorId} {
        allow read: if isMainRole() && isPhinmaedEmail();
        allow write: if (isRegistrar() || canManageBuildings()) && isPhinmaedEmail();
        // Allow dean to update floor they manage (for updating manager settings) - ONLY REGISTRAR CAN ASSIGN
        allow update: if isDean() && isPhinmaedEmail() 
          && userDocExists()
          && resource.data.managedBy == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['managedBy', 'managedByName']);

        match /rooms/{roomId} {
          allow read: if isMainRole() && isPhinmaedEmail();
          allow write: if (isRegistrar() || canManageBuildings()) && isPhinmaedEmail();
          // Allow dean to update room they manage (for updating details) - ONLY REGISTRAR CAN ASSIGN MANAGERS
          allow update: if isDean() && isPhinmaedEmail()
            && userDocExists()
            && (
              resource.data.managedBy == request.auth.uid
              || get(/databases/$(database)/documents/buildings/$(buildingId)/floors/$(floorId)).data.managedBy == request.auth.uid
            )
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['managedBy', 'managedByName']);
        }
      }
    }

    match /{path=**}/floors/{floorId} {
      allow read: if isMainRole() && isPhinmaedEmail();
      allow write: if (isRegistrar() || canManageBuildings()) && isPhinmaedEmail();
    }

    match /{path=**}/rooms/{roomId} {
      allow read: if isMainRole() && isPhinmaedEmail();
      allow write: if (isRegistrar() || canManageBuildings()) && isPhinmaedEmail();
    }

    match /approval_workflows/{workflowId} {
      allow read: if isMainRole() && isPhinmaedEmail();
      allow write: if isRegistrar() && isPhinmaedEmail();
    }

    match /room_reservations/{reservationId} {
      allow read: if isMainRole() && isPhinmaedEmail() && (
        isRegistrar()
        || resource.data.createdByUid == request.auth.uid
        || (
          isDean() 
          && userDocExists()
          && (
            // Standard workflow: dean's college matches
            (resource.data.college != null && (
              resource.data.college == userDoc().data.college
              || resource.data.college == userDoc().data.department
            ))
            // Custom manager workflow: dean is assigned to this room/floor
            || (resource.data.customManagerUid != null && resource.data.customManagerUid == request.auth.uid)
          )
        )
        || (
          hasRole('gsd')
          || hasRole('organization_head')
          || hasRole('teacher')
          || hasRole('student_life')
        )
      );
      allow create: if isMainRole() && isPhinmaedEmail()
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isMainRole() && isPhinmaedEmail() && (
        isRegistrar()
        || (
          isDean()
          && userDocExists()
          && (
            // Standard workflow: dean's college matches
            (resource.data.college != null && (
              resource.data.college == userDoc().data.college
              || resource.data.college == userDoc().data.department
            ))
            // Custom manager workflow: dean is assigned to this room/floor
            || (resource.data.customManagerUid != null && resource.data.customManagerUid == request.auth.uid)
          )
        )
        || (resource.data.createdByUid == request.auth.uid)
      );
      allow delete: if isPhinmaedEmail() && (
        isRegistrar()
        || (isMainRole() && resource.data.createdByUid == request.auth.uid)
      );
    }

    // Maintenance schedules - GSD can manage, all can read
    match /maintenance_schedules/{scheduleId} {
      allow read: if isMainRole() && isPhinmaedEmail();
      allow create, update, delete: if isPhinmaedEmail() && (
        isRegistrar() || hasRole('gsd')
      );
    }

    // Maintenance reports - all can create/read, GSD can update
    match /maintenance_reports/{reportId} {
      allow read: if isMainRole() && isPhinmaedEmail();
      allow create: if isMainRole() && isPhinmaedEmail()
        && request.resource.data.reportedByUid == request.auth.uid;
      allow update: if isPhinmaedEmail() && (
        isRegistrar() 
        || hasRole('gsd')
        || (isMainRole() && resource.data.reportedByUid == request.auth.uid)
      );
      allow delete: if isPhinmaedEmail() && (isRegistrar() || hasRole('gsd'));
    }

    // Notifications - users can read their own, system can create
    match /notifications/{notificationId} {
      allow read: if isMainRole() && isPhinmaedEmail()
        && resource.data.recipientUid == request.auth.uid;
      allow create: if isMainRole() && isPhinmaedEmail();
      allow update: if isMainRole() && isPhinmaedEmail()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      allow delete: if isRegistrar() && isPhinmaedEmail();
    }

    // Colleges inventory - Registrar can manage, all staff can read
    match /colleges/{collegeId} {
      allow read: if isMainRole() && isPhinmaedEmail();
      allow create, update, delete: if isRegistrar() && isPhinmaedEmail();
    }

    // Courses - Registrar can manage, Deans can read and assign teachers for their college courses
    match /courses/{courseId} {
      allow read: if isMainRole() && isPhinmaedEmail();
      allow create, update, delete: if isRegistrar() && isPhinmaedEmail();
      allow update: if isDean() && isPhinmaedEmail() 
        && userDocExists()
        && (
          resource.data.collegeCode == userDoc().data.college
          || resource.data.collegeCode == userDoc().data.department
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedTeacherUid', 'assignedTeacherName', 'assignedTeacherEmail', 'updatedAt']);
    }

    // Registrar operational data (scheduling, etc.) — not writable by Developers.
    match /{collection}/{document=**} {
      allow read, write: if isRegistrar() && isPhinmaedEmail()
        && collection != 'users'
        && collection != 'registrar_management'
        && collection != 'permissions'
        && collection != 'buildings'
        && collection != 'academic_calendars'
        && collection != 'schedule_plot_requests'
        && collection != 'approval_workflows'
        && collection != 'room_reservations'
        && collection != 'role_definitions';
    }

    // CollectionGroup rules for schedule entries - allows teachers to query their own schedules across all deans
    match /{path=**}/entries/{entryId} {
      allow read: if isMainRole() && isPhinmaedEmail() && userDocExists() && (
        isRegistrar()
        || hasRole('dean')
        || (hasRole('teacher') && resource.data.instructor == userDoc().data.displayName)
      );
    }
  }
}
